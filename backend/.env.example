APP_NAME="SaudiCareers"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://saudicareers.site

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=saudicareers
DB_USERNAME=
DB_PASSWORD=

# Production: use redis for cache, sessions, and queues
BROADCAST_DRIVER=log
CACHE_DRIVER=redis
FILESYSTEM_DISK=public
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail — configure your SMTP provider (e.g. SendGrid, Mailgun, SES)
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailgun.org
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@saudicareers.site"
MAIL_FROM_NAME="${APP_NAME}"

# Admin seeder password (min 12 chars, must include uppercase, lowercase, digit, special char)
ADMIN_EMAIL=admin@saudicareers.site
ADMIN_PASSWORD=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false
